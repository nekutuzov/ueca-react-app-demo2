/>

// Multiline TextField
<TextField
    labelView="Description"
    value={model.description}
    multiline={true}
    rows={4}
    placeholder="Enter description..."
/>

// Checkbox component
<Checkbox
    checked={model.agreeToTerms}
    labelView="I agree to the terms and conditions"
    onChange={(checked, source) => model.agreeToTerms = checked}
/>
