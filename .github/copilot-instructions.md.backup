<IconButton kind="delete" size="medium" onClick={() => model.delete()} />
<IconButton kind="refresh" size="medium" onClick={() => model.refresh()} />
<IconButton kind="close" size="small" onClick={() => model.close()} />

// IconButton with custom icon
<IconButton
    iconView={
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
    }
    color="warning.main"
    size="medium"
    onClick={() => console.log("Star clicked!")}
/>

// TextField component
<TextField
    labelView="Email"
    value={model.email}
    type="email"
    placeholder="your@email.com"
    required={true}
    variant="outlined"
    fullWidth={true}
    error={model.hasError}
    helperTextView="Enter a valid email address"
