**Using Tabs Components**:
```tsx
// TabsContainer with Tab children
const tabsContainer = useTabsContainer({
    props: {
        tabs: [
            useTab({
                props: {
                    tabId: "tab1",
                    labelView: "Tab One",
                    contentView: <div>Content for Tab One</div>
                }
            }),
            useTab({
                props: {
                    tabId: "tab2",
                    labelView: "Tab Two",
                    iconView: <svg>...</svg>,
                    iconPosition: "start",
                    contentView: <div>Content for Tab Two</div>
                }
            })
        ],
        selectedTabId: "tab1",  // Initial selection
        orientation: "horizontal",  // or "vertical"
        variant: "standard",  // or "scrollable", "fullWidth"
        centered: false
    },
    events: {
        onChange: (container) => {
            console.log("Selected tab:", container.selectedTab.getTabId());
        }
    }
});

// Render
<tabsContainer.View />

// Scrollable tabs with scroll buttons
<TabsContainer
    tabs={model.tabs}
    variant="scrollable"
    scrollButtons="auto"  // or true, false
    selectedTabId={model.currentTabId}
    onChange={(container) => model.handleTabChange(container)}
/>

// Vertical tabs
<TabsContainer
    tabs={model.tabs}
    orientation="vertical"
    selectedTabId={model.currentTabId}
/>

// Individual Tab with icon and wrapped text
<Tab
    tabId="settings"
    labelView="Settings & Preferences"
    iconView={<svg>...</svg>}
    iconPosition="top"  // top, bottom, start, end
    wrapped={true}
    disabled={false}
/>
```

