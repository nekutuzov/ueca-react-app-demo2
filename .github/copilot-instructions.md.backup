**Using Screen Layout Components**:
```tsx
// Basic CRUD Screen with edit intent
function useUserEditScreen(params?: UserEditScreenParams): UserEditScreenModel {
    const struct: UserEditScreenStruct = {
        props: {
            id: useUserEditScreen.name,
        },

        children: {
            crudScreen: useCRUDScreen({
                intent: "edit-record",
                breadcrumbs: [
                    { route: { path: "/" }, label: "Home" },
                    { route: { path: "/users" }, label: "Users" },
                    { route: { path: "/users/:id" }, label: "Edit User" }
                ],
                contentView: () => (
                    <Col spacing="medium">
                        <TextField 
                            labelView="Name" 
                            value={model.user.name}
                            onChange={(v) => {
                                model.user.name = v;
                                model.crudScreen.setScreenState({ dataModified: true });
                            }}
                        />
                        <TextField 
                            labelView="Email" 
                            value={model.user.email}
                            onChange={(v) => {
                                model.user.email = v;
                                model.crudScreen.setScreenState({ dataModified: true });
                            }}
                        />
                    </Col>
                ),
                onRefresh: async () => {
                    // Load user data
                    const userId = model.route.params.id;
                    model.user = await apiClient.get(`/users/${userId}`);
                },
                onValidate: async () => {
                    // Custom validation logic
                    if (!model.user.name) {
                        return false; // Fail validation
                    }
                    return true;
                },
                onSave: async () => {
                    // Save user data
                    await apiClient.put(`/users/${model.user.id}`, model.user);
                    await model.alertSuccess("User saved successfully!");
                },
                onCancel: async () => {
                    // Reload original data
                    await model.crudScreen.refresh();
                },
                onDelete: async () => {
                    // Delete user
                    await apiClient.delete(`/users/${model.user.id}`);
                    await model.alertSuccess("User deleted!");
                }
            })
        },

        View: () => <model.crudScreen.View />
    };

    const model = useUIBase(struct, params);
    return model;
}

// TabsScreen with multiple tabs
function useUserProfileScreen(params?: UserProfileScreenParams): UserProfileScreenModel {
    const struct: UserProfileScreenStruct = {
        props: {
            id: useUserProfileScreen.name,
        },

        children: {
            tabsScreen: useTabsScreen({
                intent: "edit-record",
                breadcrumbs: [
                    { route: { path: "/" }, label: "Home" },
                    { route: { path: "/profile" }, label: "Profile" }
                ],
                tabs: [
                    useTab({
                        tabId: "personal",
                        labelView: "Personal Info",
                        contentView: (
                            <Col spacing="medium">
                                <TextField labelView="First Name" value={model.user.firstName} />
                                <TextField labelView="Last Name" value={model.user.lastName} />
                            </Col>
                        )
                    }),
                    useTab({
                        tabId: "account",
                        labelView: "Account Settings",
                        contentView: (
                            <Col spacing="medium">
                                <TextField labelView="Email" value={model.user.email} />
                                <Checkbox labelView="Email Notifications" checked={model.user.emailNotifications} />
                            </Col>
                        )
                    }),
                    useTab({
                        tabId: "security",
                        labelView: "Security",
                        contentView: (
                            <Col spacing="medium">
                                <TextField labelView="Current Password" type="password" />
                                <TextField labelView="New Password" type="password" />
                            </Col>
                        )
                    })
                ],
                onRefresh: async () => {
                    model.user = await apiClient.get("/user/profile");
                },
                onSave: async () => {
                    await apiClient.put("/user/profile", model.user);
                    await model.alertSuccess("Profile updated!");
                }
            })
        },

        View: () => <model.tabsScreen.View />
    };

    const model = useUIBase(struct, params);
    return model;
}

// Using CRUDScreen state management
// Set initial state when creating new record
model.crudScreen.setScreenState({ 
    dataNew: true, 
    dataModified: true 
});

// Mark data as modified when user edits
onChange={(value) => {
    model.fieldValue = value;
    model.crudScreen.setScreenState({ dataModified: true });
}}

// Get current screen state
const state = model.crudScreen.getScreenState();
if (state.dataModified) {
    // Prompt user about unsaved changes
}

// Manually trigger operations
await model.crudScreen.refresh();  // Reload data
await model.crudScreen.validate(true);  // Validate with dialog
await model.crudScreen.save();  // Save changes
await model.crudScreen.cancel();  // Cancel changes
await model.crudScreen.delete();  // Delete record
```

When modifying this codebase:
- **Never use standard React patterns** (useState, useEffect, Context, prop drilling)
- **Never use Material-UI or other UI libraries** - use plain HTML/CSS/SVG only
- **Always use the centralized color palette** from appTheme.ts for consistency
- **Follow UECA's structured model approach** with message bus communication for component interaction
