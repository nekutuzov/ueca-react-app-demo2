**Authentication & Security**:
```tsx
// Check if user is authorized
const isAuthorized = await model.bus.unicast("App.Security.IsAuthorized");

// Login (native authentication)
await model.bus.unicast("App.Security.AuthorizeNative", {
    user: "user@example.com",
    password: "password123"
});

// Logout
await model.bus.unicast("App.Security.Unauthorize");

// Access user context directly (in Application component)
const userContext = model.security.getUserContext();
console.log(userContext.user, userContext.apiToken);

// The authorization flow:
// 1. AppLoginForm collects credentials
// 2. Calls App.Security.AuthorizeNative message
// 3. AppSecurity.authorize() sets _userContext with token
// 4. Application's binding updates: authorizedMode: () => model.security.isAuthorized()
// 5. AppUI switches from AppLoginForm to AppRouter
// 6. User sees the main application
```

**Showing Dialogs** (automatically includes severity icons):
```tsx
// Information dialog (shows info icon)
await model.bus.unicast("Dialog.Information", { 
    title: "Success", 
    message: "Operation completed." 
});

// Warning dialog (shows warning icon)
await model.bus.unicast("Dialog.Warning", { 
    title: "Warning", 
    message: "Are you sure?",
    details: "Additional details..."
});

// Error dialog (shows error icon)
await model.bus.unicast("Dialog.Error", { 
    title: "Error", 
    message: "Something went wrong.",
    details: "Error details..."
});

// Exception dialog
try {
    await riskyOperation();
} catch (error) {
    await model.bus.unicast("Dialog.Exception", { 
        title: "Operation Failed",
        error 
    });
}

// Confirmation dialog
const confirmed = await model.bus.unicast("Dialog.Confirmation", { 
    title: "Confirm", 
    message: "Proceed with this action?" 
});

// Action confirmation with custom button text
const confirmed = await model.bus.unicast("Dialog.ActionConfirmation", { 
    title: "Delete", 
    message: "This action cannot be undone.",
    action: "Delete"
});
```

**Showing Alerts** (toast notifications):
```tsx
// Success alert
await model.bus.unicast("Alert.Success", { 
    message: "Operation completed successfully!" 
});

// Information alert
await model.bus.unicast("Alert.Information", { 
    message: "Your changes have been saved." 
});

// Warning alert
await model.bus.unicast("Alert.Warning", { 
    message: "Please review your input before submitting." 
});

// Error alert
await model.bus.unicast("Alert.Error", { 
    message: "Failed to save changes. Please try again." 
});

// Multiple alerts stack automatically
await model.bus.unicast("Alert.Success", { message: "First notification" });
await model.bus.unicast("Alert.Information", { message: "Second notification" });
// Both appear stacked at configured position (default: bottom-right), auto-dismiss after 4 seconds

// Configure alert position in AppUI (optional)
alertManager: useAppAlertManager({
    anchorOrigin: { vertical: "top", horizontal: "center" }  // top-center positioning
})
// Supports: top/bottom × left/center/right (6 positions)
```

**Navigating with Routing**:
```tsx
// Get current route
const currentRoute = await model.bus.unicast("App.Router.GetRoute");
console.log(currentRoute.path, currentRoute.params);

// Navigate to a route (adds to history)
await model.bus.unicast("App.Router.GoToRoute", { 
    path: "/users/:id", 
    params: { id: "123" } 
});

// Navigate without history (replaces current state)
await model.bus.unicast("App.Router.SetRoute", { 
    path: "/home" 
});

// Update route params without changing path
await model.bus.unicast("App.Router.SetRouteParams", { 
    params: { tab: "settings" }, 
    patch: true  // merge with existing params
});

// Open route in new browser tab
await model.bus.unicast("App.Router.OpenNewTab", { 
    path: "/users/:id", 
    params: { id: "456" } 
});

// Hook before route change (can cancel navigation)
messages: {
    "App.Router.BeforeRouteChange": async (route) => {
        if (model.hasUnsavedChanges) {
            const confirm = await model.bus.unicast("Dialog.Confirmation", {
                message: "You have unsaved changes. Continue?"
            });
            return confirm;  // Return false to cancel navigation
        }
        return true;  // Allow navigation
    }
}

// Hook after route change
messages: {
    "App.Router.AfterRouteChange": async (route) => {
        console.log("Navigated to:", route.path);
        // Update analytics, breadcrumbs, etc.
    }
}

// Define routes in appRoutes.tsx
const screenRoutes = {
    "/": () => <HomeScreen id={"homeScreen"} />,
    "/users/:id": () => <UserDetailScreen id={"userDetailScreen"} />,
    "/settings?:tab": () => <SettingsScreen id={"settingsScreen"} />
};
```

